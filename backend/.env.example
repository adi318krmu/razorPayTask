# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (Supabase PostgreSQL Connection String)
# Use the connection pooler string (port 6543) for serverless/pooled environments
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-[YOUR-REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Authentication / JWT Configuration
JWT_SECRET=super_secret_jwt_passphrase_change_me_in_production
JWT_EXPIRES_IN=24h

# Cookie configuration
COOKIE_SECRET=cookie_secret_passphrase_change_me
